PORT=5000
# MongoDB Atlas Connection String
# To get this string:
# 1. Go to https://www.mongodb.com/atlas
# 2. Create an account or log in
# 3. Create a new cluster (the free tier is fine for development)
# 4. Create a database user with username and password
# 5. Go to Database Access and add your IP address (or allow access from anywhere for development)
# 6. Click Connect and choose 'Connect your application'
# 7. Copy the connection string and replace <password> with your database user's password
# 8. Replace the placeholder below with your actual connection string
# Example format: mongodb+srv://username:password@clustername.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/gradech
JWT_SECRET=supersecretkey123
